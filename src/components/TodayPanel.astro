---
const defaultCity = '北京';
---

<section class="today-panel" aria-label="今日信息">
  <div class="today-card time-card">
    <span class="eyebrow">现在</span>
    <strong id="local-time">--:--:--</strong>
    <span id="local-date">正在读取日期</span>
  </div>
  <div class="today-card weather-card">
    <span class="eyebrow">天气</span>
    <strong id="weather-temp">读取中</strong>
    <span id="weather-desc" data-city={defaultCity}>默认城市：{defaultCity}</span>
  </div>
</section>

<script>
  const timeNode = document.querySelector('#local-time');
  const dateNode = document.querySelector('#local-date');
  const weatherTemp = document.querySelector('#weather-temp');
  const weatherDesc = document.querySelector('#weather-desc');

  function updateTime() {
    const now = new Date();
    if (timeNode) {
      timeNode.textContent = now.toLocaleTimeString('zh-CN', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
    }
    if (dateNode) {
      dateNode.textContent = now.toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        weekday: 'long'
      });
    }
  }

  async function updateWeather() {
    if (!weatherTemp || !weatherDesc) return;
    const city = weatherDesc.getAttribute('data-city') || '北京';

    try {
      const response = await fetch(`https://wttr.in/${encodeURIComponent(city)}?format=j1`);
      if (!response.ok) throw new Error('weather request failed');
      const data = await response.json();
      const current = data.current_condition?.[0];
      const temp = current?.temp_C;
      const desc = current?.lang_zh?.[0]?.value || current?.weatherDesc?.[0]?.value;

      weatherTemp.textContent = temp ? `${temp}°C` : '暂无数据';
      weatherDesc.textContent = desc ? `${city} · ${desc}` : `${city} · 天气数据暂不可用`;
    } catch {
      weatherTemp.textContent = '天气暂不可用';
      weatherDesc.textContent = `${city} · 稍后再看`;
    }
  }

  updateTime();
  setInterval(updateTime, 1000);
  updateWeather();
</script>
