<section class="today-panel" aria-label="今日信息">
  <div class="today-card time-card">
    <span class="eyebrow">现在</span>
    <strong id="local-time">--:--:--</strong>
    <span id="local-date">正在读取日期</span>
  </div>
  <div class="today-card weather-card">
    <span class="eyebrow">天气</span>
    <strong id="weather-temp">定位中</strong>
    <span id="weather-desc">允许定位后显示所在城市天气</span>
  </div>
</section>

<script>
  const timeNode = document.querySelector('#local-time');
  const dateNode = document.querySelector('#local-date');
  const weatherTemp = document.querySelector('#weather-temp');
  const weatherDesc = document.querySelector('#weather-desc');

  const weatherNames: Record<number, string> = {
    0: '晴',
    1: '大部晴朗',
    2: '局部多云',
    3: '阴',
    45: '雾',
    48: '雾凇',
    51: '小毛毛雨',
    53: '毛毛雨',
    55: '强毛毛雨',
    61: '小雨',
    63: '中雨',
    65: '大雨',
    71: '小雪',
    73: '中雪',
    75: '大雪',
    80: '阵雨',
    81: '较强阵雨',
    82: '强阵雨',
    95: '雷暴',
    96: '雷暴伴冰雹',
    99: '强雷暴伴冰雹'
  };

  function updateTime() {
    const now = new Date();
    if (timeNode) {
      timeNode.textContent = now.toLocaleTimeString('zh-CN', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
    }
    if (dateNode) {
      dateNode.textContent = now.toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        weekday: 'long'
      });
    }
  }

  function getPosition(): Promise<GeolocationPosition> {
    return new Promise((resolve, reject) => {
      if (!navigator.geolocation) {
        reject(new Error('geolocation unavailable'));
        return;
      }
      navigator.geolocation.getCurrentPosition(resolve, reject, {
        enableHighAccuracy: false,
        timeout: 8000,
        maximumAge: 1000 * 60 * 30
      });
    });
  }

  async function resolveCity(latitude: number, longitude: number) {
    const url = `https://geocoding-api.open-meteo.com/v1/reverse?latitude=${latitude}&longitude=${longitude}&language=zh&count=1`;
    const response = await fetch(url);
    if (!response.ok) return '当前位置';
    const data = await response.json();
    return data.results?.[0]?.name || data.results?.[0]?.admin1 || '当前位置';
  }

  async function getIpLocation() {
    const response = await fetch('https://ipwho.is/?lang=zh-CN');
    if (!response.ok) throw new Error('ip location request failed');
    const data = await response.json();
    if (data.success === false || typeof data.latitude !== 'number' || typeof data.longitude !== 'number') {
      throw new Error('ip location unavailable');
    }

    return {
      latitude: data.latitude,
      longitude: data.longitude,
      city: data.city || data.region || data.country || '当前位置'
    };
  }

  async function fetchWeather(latitude: number, longitude: number) {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,weather_code&timezone=auto`;
    const response = await fetch(url);
    if (!response.ok) throw new Error('weather request failed');
    return response.json();
  }

  async function updateWeather() {
    if (!weatherTemp || !weatherDesc) return;

    let latitude = 39.9042;
    let longitude = 116.4074;
    let city = '北京';
    let locationSource = '默认';

    try {
      const position = await getPosition();
      latitude = position.coords.latitude;
      longitude = position.coords.longitude;
      city = await resolveCity(latitude, longitude);
      locationSource = '浏览器定位';
    } catch (error) {
      try {
        const ipLocation = await getIpLocation();
        latitude = ipLocation.latitude;
        longitude = ipLocation.longitude;
        city = ipLocation.city;
        locationSource = 'IP定位';
      } catch {
        weatherDesc.textContent = '定位失败，显示默认城市北京';
      }
    }

    try {
      const data = await fetchWeather(latitude, longitude);
      const current = data.current;
      const temp = Math.round(current?.temperature_2m);
      const weatherCode = Number(current?.weather_code);
      const weather = weatherNames[weatherCode] || '天气更新中';
      weatherTemp.textContent = Number.isFinite(temp) ? `${temp}°C` : '暂无数据';
      weatherDesc.textContent = `${city} · ${weather} · ${locationSource}`;
    } catch {
      weatherTemp.textContent = '天气暂不可用';
      weatherDesc.textContent = `${city} · 稍后再看`;
    }
  }

  updateTime();
  setInterval(updateTime, 1000);
  updateWeather();
</script>
