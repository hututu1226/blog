---
import { siteName, withBase } from '../lib/site';

const links = [
  { href: withBase('/'), label: '首页' },
  { href: withBase('/posts/'), label: '博客' },
  { href: withBase('/categories/'), label: '分类' },
  { href: withBase('/about/'), label: '关于' }
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === withBase('/')) return currentPath === href;
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-shell nav">
    <a class="brand" href={withBase('/')} aria-label={`${siteName} 首页`}>
      <span class="brand-title">{siteName}</span>
      <span class="brand-mark">hututu1226</span>
    </a>
    <nav class="nav-links" aria-label="主导航">
      {
        links.map((link) => (
          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
