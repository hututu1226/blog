---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { postUrl } from '../lib/posts';
import { withBase } from '../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="归档" description="按时间归档的全部文章。">
  <section class="site-shell page">
    <header class="page-header">
      <h1>归档</h1>
      <p>所有文章按发布时间倒序排列。</p>
    </header>
    <div class="archive-list">
      {
        posts.map((post) => (
          <article class="archive-item">
            <time class="archive-date" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
            <div>
              <a href={postUrl(post)}>{post.data.title}</a>
              <div class="meta">
                <a href={withBase(`/categories/${encodeURIComponent(post.data.category)}/`)}>{post.data.category}</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
