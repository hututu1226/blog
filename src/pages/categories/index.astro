---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { postUrl } from '../../lib/posts';
import { withBase } from '../../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryNames = ['知识管理', '项目', '阅读', '生活杂谈'];
const categories = categoryNames.map((category) => ({
  name: category,
  posts: posts.filter((post) => post.data.category === category)
}));
---

<BaseLayout title="分类" description="按主题分类浏览博客文章。">
  <section class="site-shell page">
    <header class="page-header">
      <span class="eyebrow">Categories</span>
      <h1>博客分类</h1>
      <p>目前固定为四个栏目：知识管理、项目、阅读、生活杂谈。后续新增文章时优先归入这四类。</p>
    </header>

    <div class="category-overview">
      {
        categories.map((category) => (
          <a class="category-tile" href={withBase(`/categories/${encodeURIComponent(category.name)}/`)}>
            <strong>{category.name}</strong>
            <span>{category.posts.length} 篇文章</span>
          </a>
        ))
      }
    </div>

    <div class="category-sections">
      {
        categories.map((category) => (
          <section class="category-section">
            <div class="category-section-header">
              <h2>{category.name}</h2>
              <a href={withBase(`/categories/${encodeURIComponent(category.name)}/`)}>进入分类</a>
            </div>
            <div class="archive-list">
              {
                category.posts.length > 0 ? (
                  category.posts.map((post) => (
                    <article class="archive-item">
                      <time class="archive-date" datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('zh-CN')}
                      </time>
                      <a href={postUrl(post)}>{post.data.title}</a>
                    </article>
                  ))
                ) : (
                  <p class="empty-note">这个分类还没有文章。</p>
                )
              }
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
