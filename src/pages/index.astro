---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import MascotIcon from '../components/MascotIcon.astro';
import PostCard from '../components/PostCard.astro';
import TodayPanel from '../components/TodayPanel.astro';
import { withBase } from '../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout>
  <section class="site-shell home-hero">
    <div class="home-copy">
      <span class="eyebrow">hututu1226 的个人博客</span>
      <h1>每天进步一点点</h1>
      <p>
        记录学习、项目、阅读和生活里的持续积累。先把每一天的输入和实践留下来，再慢慢形成自己的知识地图。
      </p>
      <div class="hero-actions">
        <a class="button-primary" href={withBase('/posts/')}>阅读博客</a>
        <a class="button-secondary" href={withBase('/about/')}>了解我</a>
      </div>
    </div>
    <div class="home-visual">
      <MascotIcon />
      <TodayPanel />
    </div>
  </section>

  <section class="site-shell home-section">
    <div class="section-heading">
      <div>
        <span class="eyebrow">最新内容</span>
        <h2>最近写下的东西</h2>
      </div>
      <a href={withBase('/posts/')}>查看全部</a>
    </div>
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
