---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TodayPanel from '../components/TodayPanel.astro';
import { withBase } from '../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = ['知识管理', '项目', '阅读', '生活杂谈'];
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const categoryCounts = new Map(
  categories.map((category) => [
    category,
    allPosts.filter((post) => post.data.category === category).length
  ])
);
---

<BaseLayout>
  <section class="home-hero-photo" style={`background-image: url('${withBase('/hero-mountain.jpg')}')`}>
    <div class="hero-overlay site-shell">
      <h1>每天进步一点点</h1>
      <TodayPanel />
      <p class="daily-note">把今天值得记住的东西留下来，明天就会多一个可以回看的坐标。</p>
    </div>
  </section>

  <section class="site-shell home-section home-content-grid">
    <aside class="category-rail" aria-label="博客分类">
      <span class="eyebrow">Categories</span>
      <h2>博客分类</h2>
      <nav>
        {
          categories.map((category) => (
            <a href={withBase(`/categories/${encodeURIComponent(category)}/`)}>
              <span>{category}</span>
              <small>{categoryCounts.get(category) ?? 0}</small>
            </a>
          ))
        }
      </nav>
    </aside>

    <div>
      <div class="section-heading">
        <div>
          <span class="eyebrow">Latest</span>
          <h2>最近写下的东西</h2>
        </div>
        <a href={withBase('/posts/')}>查看全部</a>
      </div>
      <div class="post-list">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
