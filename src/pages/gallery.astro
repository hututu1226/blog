---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
import galleryItems from '../data/gallery.json';

const sortedGalleryItems = [...galleryItems].sort((a, b) => {
  const timeA = a.date ? new Date(a.date).valueOf() : 0;
  const timeB = b.date ? new Date(b.date).valueOf() : 0;
  return timeB - timeA;
});
---

<BaseLayout title="照片墙" description="照片、视频和生活瞬间的集合。">
  <section class="site-shell page">
    <header class="page-header">
      <span class="eyebrow">Gallery</span>
      <h1>照片墙</h1>
      <p>这里可以放照片、视频和一小段描述，用来记录生活中的美好瞬间。</p>
    </header>

    <div class="gallery-grid">
      {
        sortedGalleryItems.map((item, index) => (
          <article class="gallery-card">
            {
              item.type === 'image' ? (
                <button
                  class="gallery-open"
                  type="button"
                  data-full-src={withBase(item.src)}
                  data-title={item.title}
                  data-description={item.description}
                  data-date={item.date}
                  data-location={item.location}
                  data-index={index}
                  aria-label={`放大查看 ${item.title}`}
                >
                  <img src={withBase(item.src)} alt={item.title} loading="lazy" />
                </button>
              ) : (
                <video src={withBase(item.src)} controls preload="metadata" />
              )
            }
            <div>
              <h2>{item.title}</h2>
              <p class="gallery-meta">
                {[item.date, item.location].filter(Boolean).join(' · ')}
              </p>
              <p>{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>

  </section>

  <div class="gallery-lightbox" id="gallery-lightbox" aria-hidden="true">
    <button class="gallery-lightbox-backdrop" type="button" aria-label="关闭图片预览"></button>
    <figure class="gallery-lightbox-content" role="dialog" aria-modal="true" aria-label="图片预览">
      <div class="gallery-lightbox-media">
        <button class="gallery-lightbox-close" type="button" aria-label="关闭图片预览">×</button>
        <img id="gallery-lightbox-image" alt="" />
      </div>
      <figcaption>
        <strong id="gallery-lightbox-title"></strong>
        <em id="gallery-lightbox-meta"></em>
        <span id="gallery-lightbox-description"></span>
      </figcaption>
      <button class="gallery-lightbox-nav gallery-lightbox-prev" type="button" aria-label="上一张">‹</button>
      <button class="gallery-lightbox-nav gallery-lightbox-next" type="button" aria-label="下一张">›</button>
    </figure>
  </div>
</BaseLayout>

<script>
  const lightbox = document.querySelector('#gallery-lightbox');
  const lightboxImage = document.querySelector('#gallery-lightbox-image') as HTMLImageElement | null;
  const lightboxTitle = document.querySelector('#gallery-lightbox-title');
  const lightboxMeta = document.querySelector('#gallery-lightbox-meta');
  const lightboxDescription = document.querySelector('#gallery-lightbox-description');
  const openButtons = document.querySelectorAll<HTMLButtonElement>('.gallery-open');
  const closeButtons = document.querySelectorAll('.gallery-lightbox-close, .gallery-lightbox-backdrop');
  const prevButton = document.querySelector('.gallery-lightbox-prev');
  const nextButton = document.querySelector('.gallery-lightbox-next');
  let currentIndex = 0;
  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  let dragStartX = 0;
  let dragStartY = 0;
  let startTranslateX = 0;
  let startTranslateY = 0;
  let isDragging = false;
  const dragSensitivity = 50;

  function applyImageTransform() {
    if (!lightboxImage) return;
    lightboxImage.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    lightboxImage.classList.toggle('is-dragging', isDragging);
  }

  function resetImageTransform() {
    scale = 1;
    translateX = 0;
    translateY = 0;
    isDragging = false;
    applyImageTransform();
  }

  function openLightbox(index: number) {
    const button = openButtons[index];
    if (!button || !lightbox || !lightboxImage || !lightboxTitle || !lightboxMeta || !lightboxDescription) return;

    const src = button.dataset.fullSrc || '';
    const title = button.dataset.title || '';
    const description = button.dataset.description || '';
    const meta = [button.dataset.date, button.dataset.location].filter(Boolean).join(' · ');

    currentIndex = index;
    resetImageTransform();
    lightboxImage.src = src;
    lightboxImage.alt = title;
    lightboxTitle.textContent = title;
    lightboxMeta.textContent = meta;
    lightboxDescription.textContent = description;
    lightbox.setAttribute('aria-hidden', 'false');
    document.documentElement.classList.add('lightbox-open');
  }

  function closeLightbox() {
    if (!lightbox || !lightboxImage) return;

    lightbox.setAttribute('aria-hidden', 'true');
    lightboxImage.removeAttribute('src');
    resetImageTransform();
    document.documentElement.classList.remove('lightbox-open');
  }

  openButtons.forEach((button) => {
    button.addEventListener('click', () => openLightbox(Number(button.dataset.index || 0)));
  });

  closeButtons.forEach((button) => {
    button.addEventListener('click', closeLightbox);
  });

  prevButton?.addEventListener('click', () => {
    const nextIndex = (currentIndex - 1 + openButtons.length) % openButtons.length;
    openLightbox(nextIndex);
  });

  nextButton?.addEventListener('click', () => {
    const nextIndex = (currentIndex + 1) % openButtons.length;
    openLightbox(nextIndex);
  });

  lightboxImage?.addEventListener('wheel', (event) => {
    event.preventDefault();
    const nextScale = Math.min(4, Math.max(0.6, scale + (event.deltaY > 0 ? -0.14 : 0.14)));
    if (nextScale === 1) {
      translateX = 0;
      translateY = 0;
    }
    scale = nextScale;
    applyImageTransform();
  });

  lightboxImage?.addEventListener('pointerdown', (event) => {
    if (event.button !== 2) return;
    event.preventDefault();
    isDragging = true;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    startTranslateX = translateX;
    startTranslateY = translateY;
    lightboxImage.setPointerCapture(event.pointerId);
    applyImageTransform();
  });

  lightboxImage?.addEventListener('pointermove', (event) => {
    if (!isDragging) return;
    event.preventDefault();
    translateX = startTranslateX + (event.clientX - dragStartX) * dragSensitivity;
    translateY = startTranslateY + (event.clientY - dragStartY) * dragSensitivity;
    applyImageTransform();
  });

  function stopDragging() {
    isDragging = false;
    applyImageTransform();
  }

  lightboxImage?.addEventListener('pointerup', stopDragging);
  lightboxImage?.addEventListener('pointercancel', stopDragging);
  lightboxImage?.addEventListener('lostpointercapture', stopDragging);
  lightboxImage?.addEventListener('contextmenu', (event) => {
    event.preventDefault();
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeLightbox();
    if (event.key === 'ArrowLeft') {
      const nextIndex = (currentIndex - 1 + openButtons.length) % openButtons.length;
      openLightbox(nextIndex);
    }
    if (event.key === 'ArrowRight') {
      const nextIndex = (currentIndex + 1) % openButtons.length;
      openLightbox(nextIndex);
    }
  });
</script>
