---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
---

<BaseLayout title="关于" description="关于 hututu1226 和这个博客。">
  <section class="site-shell page about-page">
    <header class="page-header about-header">
      <div>
        <span class="eyebrow">About</span>
        <h1>关于 hututu1226</h1>
      </div>
      <img class="brand-avatar about-avatar" src={withBase('/hututu.jpg')} alt="hututu1226 头像" />
    </header>

    <div class="about-grid">
      <section>
        <h2>我会在这里写什么</h2>
        <p>
          这个博客会记录学习笔记、项目复盘、工具使用、阅读感想和生活观察。
        </p>
      </section>
      <section>
        <h2>当前关注</h2>
        <ul>
          <li>把复杂问题拆成可执行的小步骤</li>
          <li>记录真实项目里的判断和取舍</li>
          <li>养成稳定写作和复盘的习惯</li>
          <li>记录生活中的美好瞬间</li>
        </ul>
      </section>
      <section>
        <h2>联系</h2>
        <p>
          GitHub：<a href="https://github.com/hututu1226">hututu1226</a>
        </p>
        <p>邮箱：<a href="mailto:1317101097@qq.com">1317101097@qq.com</a></p>
        <p>微信：Twistzz20001226</p>
      </section>
    </div>
  </section>
</BaseLayout>
