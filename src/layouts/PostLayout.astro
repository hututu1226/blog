---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/site';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const date = post.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="meta">
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        <a href={withBase(`/categories/${encodeURIComponent(post.data.category)}/`)}>{post.data.category}</a>
      </div>
      <div class="tag-list">
        {post.data.tags.map((tag) => <a class="tag" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>{tag}</a>)}
      </div>
    </header>
    <div class="article-body">
      <slot />
    </div>
  </article>
</BaseLayout>
